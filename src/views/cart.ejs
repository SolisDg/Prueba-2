<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head') %>
    <style>
        .cart-page {
            padding: 40px 20px;
            max-width: 1200px;
            margin: 0 auto;
        }
        .cart-title {
            margin-bottom: 30px;
            text-align: center;
        }
        .cart-container {
            display: flex;
            gap: 30px;
            flex-wrap: wrap;
        }
        .cart-items {
            flex: 2;
            min-width: 300px;
        }
        .cart-summary {
            flex: 1;
            min-width: 300px;
            background: #f9f9f9;
            padding: 20px;
            border-radius: 8px;
            height: fit-content;
        }
        .cart-item {
            display: flex;
            align-items: center;
            border-bottom: 1px solid #ddd;
            padding: 15px 0;
            gap: 15px;
        }
        .cart-item img {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 8px;
        }
        .item-details {
            flex: 1;
        }
        .item-details h4 {
            margin: 0 0 5px 0;
        }
        .item-price {
            font-weight: bold;
            color: #333;
        }
        .item-quantity {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 10px;
        }
        .item-quantity button {
            background: #eee;
            border: none;
            padding: 5px 10px;
            cursor: pointer;
            border-radius: 4px;
        }
        .item-remove {
            color: red;
            background: none;
            border: none;
            cursor: pointer;
        }
        .summary-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 15px;
        }
        .summary-total {
            font-size: 1.2em;
            font-weight: bold;
            border-top: 1px solid #ccc;
            padding-top: 15px;
            margin-top: 15px;
        }
        .checkout-btn {
            width: 100%;
            padding: 12px;
            background-color: var(--primary-color, #007bff);
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 1.1em;
            cursor: pointer;
            transition: background 0.3s;
        }
        .checkout-btn:hover {
            opacity: 0.9;
        }
        .empty-cart {
            text-align: center;
            padding: 50px 0;
        }
    </style>
</head>
<body>
    <%- include('partials/header') %>
    <main class="cart-page">
        <h1 class="cart-title">Tu Carrito de Compras</h1>
        <div class="cart-container">
            <div class="cart-items" id="cart-items-container">
                <!-- Se llenará dinámicamente con JS -->
            </div>
            
            <div class="cart-summary" id="cart-summary-container" style="display: none;">
                <h3>Resumen de la compra</h3>
                <div class="summary-row">
                    <span>Subtotal</span>
                    <span id="summary-subtotal">$0.00</span>
                </div>
                <div class="summary-row">
                    <span>Envío</span>
                    <span>Gratis</span>
                </div>
                <div class="summary-row summary-total">
                    <span>Total</span>
                    <span id="summary-total">$0.00</span>
                </div>
                <button class="checkout-btn" onclick="alert('Checkout en desarrollo :)')">Proceder al Pago</button>
            </div>
        </div>
    </main>
    <%- include('partials/footer') %>
</body>
</html>
