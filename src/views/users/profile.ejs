<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
</head>
<body>
    <%- include('../partials/header') %>
    <main>
        <div class="container">
            <div class="auth-container" style="max-width: 600px;">
                <div class="auth-header">
                    <h1>Mi Perfil</h1>
                    <p>¡Hola de nuevo!</p>
                </div>

                <div class="profile-content" style="text-align: center;">
                    <img src="/images/users/<%= user.avatar %>" alt="Avatar" style="width: 150px; height: 150px; border-radius: 50%; object-fit: cover; margin-bottom: 20px; border: 4px solid var(--color-secondary);">
                    
                    <h2 style="margin-bottom: 10px;"><%= user.name %></h2>
                    <p style="color: var(--text-light); margin-bottom: 30px;"><%= user.email %></p>

                    <div class="profile-actions" style="display: flex; gap: 10px; justify-content: center;">
                        <a href="/" class="btn btn-outline">Volver al inicio</a>
                        <a href="/users/logout" class="btn btn-danger">Cerrar sesión</a>
                    </div>
                </div>
            </div>
        </div>
    </main>
    <%- include('../partials/footer') %>
</body>
</html>
