
<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="auth-page">
    <div class="auth-container">
        <h1>Crear cuenta</h1>
        <p class="subtitle">Únete a Pretty Thermo</p>
        <% if (typeof errors !== 'undefined' && errors.length >0) { %>
            <div class="alert alert-error">
                <ul>
                    <% errors.forEach(error => { %>
                        <li><%= error.msg %></li>
                    <% }) %>
                </ul>
            </div>
        <% } %>
        <form action="/users/register" method="POST" enctype="multipart/form-data">
            <div class="form-row">
                <div class="form-group">
                    <label for="firstName">Nombre *</label>
                    <input type="text" id="firstName" name="firstName" 
                    value="<%= typeof old !== 'undefined' ? old.firstName : '' %>" required>
                    
                </div>
                <div class="form-group">
                    <label for="lastName">Apellido *</label>
                    <input type="text" id="lastName" name="lastName"
                    value="<%= typeof old !== 'undefined' ? old.lastName : '' %>" required>
                </div>
            </div>
            <div class="form-group">
                <label for="email">Email *</label>
                <input 
                    type="email" id="email" name="email" 
                    value="<%= typeof old !== 'undefined' ? old.email : '' %>" required>
            </div>
            <div class="form-group">
                <label for="password">Contraseña *</label>
                <input type="password" id="password" name="password" minlength="8" required>
                <small>Mínimo 8 caracteres</small>
            </div>
            <div class="form-group">
                <label for="confirmPassword">Confirmar contraseña *</label>
                <input type="password" id="confirmPassword" name="confirmPassword" required>
            </div>
            <div class="form-group">
                <label for="avatar">Foto de perfil</label>
                <input type="file" id="avatar" name="avatar" accept="image/*">
            </div>

            <button type="submit" class="btn btn-primary btn-block">Crear cuenta</button>
        </form>
        <p class="auto-link">¿Ya tienes cuenta? <a href="/users/login">Inicia sesión</a></p>
        
    </div>
</main>
<%- include('../partials/footer') %>
