<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
</head>
<body>
    <%- include('../partials/header') %>
    <main class="auth-page">
        <div class="auth-container">
            <div class="auth-header">
                <h1>Crear cuenta</h1>
                <p>Únete a la comunidad de Pretty Thermo ✨</p>
            </div>
            
            <form id="registerForm" action="/users/register" method="POST" enctype="multipart/form-data">
                
                <div class="form-group">
                    <label for="name" class="form-label">Nombre completo *</label>
                    <input 
                        type="text" 
                        name="name" 
                        id="name"
                        value="<%= (typeof old !== 'undefined' && old.name) ? old.name : '' %>"
                        class="form-control <%= (typeof errors !== 'undefined' && errors.name) ? 'is-invalid' : '' %>"
                        placeholder="Ej: Ana García"
                    >
                    <% if (typeof errors !== 'undefined' && errors.name) { %>
                        <small class="error-message"><%= errors.name.msg %></small>
                    <% } %>
                </div>
                
                <div class="form-group">
                    <label for="email" class="form-label">Email *</label>
                    <input 
                        type="email" 
                        name="email" 
                        id="email"
                        value="<%= (typeof old !== 'undefined' && old.email) ? old.email : '' %>"
                        class="form-control <%= (typeof errors !== 'undefined' && errors.email) ? 'is-invalid' : '' %>"
                        placeholder="tu@email.com"
                    >
                    <% if (typeof errors !== 'undefined' && errors.email) { %>
                        <small class="error-message"><%= errors.email.msg %></small>
                    <% } %>
                </div>
                
                <div class="form-group">
                    <label for="password" class="form-label">Contraseña *</label>
                    <input 
                        type="password" 
                        name="password" 
                        id="password"
                        class="form-control <%= (typeof errors !== 'undefined' && errors.password) ? 'is-invalid' : '' %>"
                        placeholder="Mínimo 8 caracteres"
                    >
                    <% if (typeof errors !== 'undefined' && errors.password) { %>
                        <small class="error-message"><%= errors.password.msg %></small>
                    <% } %>
                </div>
                
                <div class="form-group">
                    <label for="confirmPassword" class="form-label">Confirmar Contraseña *</label>
                    <input 
                        type="password" 
                        name="confirmPassword" 
                        id="confirmPassword"
                        class="form-control <%= (typeof errors !== 'undefined' && errors.confirmPassword) ? 'is-invalid' : '' %>"
                        placeholder="Repite tu contraseña"
                    >
                    <% if (typeof errors !== 'undefined' && errors.confirmPassword) { %>
                        <small class="error-message"><%= errors.confirmPassword.msg %></small>
                    <% } %>
                </div>
                
                <div class="form-group">
                    <label for="avatar" class="form-label">Foto de perfil</label>
                    <input 
                        type="file" 
                        name="avatar" 
                        id="avatar"
                        accept="image/*"
                        class="form-control <%= (typeof errors !== 'undefined' && errors.avatar) ? 'is-invalid' : '' %>"
                    >
                    <% if (typeof errors !== 'undefined' && errors.avatar) { %>
                        <small class="error-message"><%= errors.avatar.msg %></small>
                    <% } %>
                </div>

                <button type="submit" class="btn btn-primary btn-block">Registrarme</button>
            </form>
            <div class="auth-footer">
                <p>¿Ya tienes cuenta? <a href="/users/login">Inicia sesión aquí</a></p>
            </div>
        </div>
    </main>
    <%- include('../partials/footer') %>
    <script src="/js/validations.js"></script>
</body>
</html>