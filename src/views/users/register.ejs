
<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="auth-page">
    <div class="auth-container">
        <h1>Crear cuenta</h1>
        <form id="registerForm" action="/users/register" method="POST" enctype="multipart/form-data">
            
            <div class="form-group">
                <label for="name">Nombre *</label>
                <input 
                    type="text" 
                    name="name" 
                    id="name"
                    value="<%= old.name || '' %>"
                    class="<%= errors.name ? 'is-invalid' : '' %>"
                    placeholder="Tu nombre completo"
                >
                <!-- Mostrar error si existe -->
                <% if (errors.name) { %>
                    <small class="error-message"><%= errors.name.msg %></small>
                <% } %>
            </div>
            
            <div class="form-group">
                <label for="email">Email *</label>
                <input 
                    type="email" 
                    name="email" 
                    id="email"
                    value="<%= old.email || '' %>"
                    class="<%= errors.email ? 'is-invalid' : '' %>"
                    placeholder="tu@email.com"
                >
                <% if (errors.email) { %>
                    <small class="error-message"><%= errors.email.msg %></small>
                <% } %>
            </div>
            
            <div class="form-group">
                <label for="password">Contraseña *</label>
                <input 
                    type="password" 
                    name="password" 
                    id="password"
                    class="<%= errors.password ? 'is-invalid' : '' %>"
                    placeholder="Mínimo 8 caracteres"
                >
                <small class="hint">Debe incluir mayúscula, minúscula, número y carácter especial</small>
                <% if (errors.password) { %>
                    <small class="error-message"><%= errors.password.msg %></small>
                <% } %>
            </div>
            
            <div class="form-group">
                <label for="confirmPassword">Confirmar Contraseña *</label>
                <input 
                    type="password" 
                    name="confirmPassword" 
                    id="confirmPassword"
                    class="<%= errors.confirmPassword ? 'is-invalid' : '' %>"
                    placeholder="Repite tu contraseña"
                >
                <% if (errors.confirmPassword) { %>
                    <small class="error-message"><%= errors.confirmPassword.msg %></small>
                <% } %>
            </div>
            
            <div class="form-group">
                <label for="avatar">Foto de perfil (opcional)</label>
                <input 
                    type="file" 
                    name="avatar" 
                    id="avatar"
                    accept="image/*"
                    class="<%= errors.avatar ? 'is-invalid' : '' %>"
                >
                <% if (errors.avatar) { %>
                    <small class="error-message"><%= errors.avatar.msg %></small>
                <% } %>
            </div>
            <button type="submit" class="btn btn-primary">Crear Cuenta</button>
        </form>
        <p class="auth-link"> ¿Ya tienes cuenta? <a href="/users/login">Inicia sesión</a></p>
    </div>
</main>

<script src="/js/validations.js"></script>
<%- include('../partials/footer') %>