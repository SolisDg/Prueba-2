
<%- include('../partials/head') %>
<%- include('../partials/header') %>
<main class="auth-page">
    <div class="auth-container">
        <h1>Iniciar Sesión</h1>
        <p class="subtitle">Bienvenido de vuelta 🥳</p>
        <% if (typeof error !== 'undefined' && errors.lenght > 0) {%>
            <div class="alert alert-error">
                <ul>
                    <% errors.forEach(error => {%>
                        <li><%= error.msg %></li>

                    <% })%>
                </ul>
            </div>

        <% } %>
        <form action="/usuarios/login" method="POST">
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" 
                value="<%= typeof old !== 'undefined' ? old.email : '' %> " required>
            </div>
            <div class="form-group">
                <label for="password">Contraseña</label>
                <input type="password" id="password" name="password" required>
            </div>
            <div class="form-group checkbox-group">
                <input type="checkbox" id="rememberMe" name="rememberMe">
                <label for="rememberMe">Recordarme</label>
            </div>
            <button type="submit" class="btn btn-primary btn-block">Iniciar sesión</button>
        </form>
        <p class="auth-link">¿No tienes cuenta? <a href="/users/register">Regístrate</a></p>
    </div>
</main>
<%- include('../partials/footer') %>