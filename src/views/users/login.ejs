<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
</head>
<body>
    <%- include('../partials/header') %>
    <main class="auth-page">
        <div class="auth-container">
            <div class="auth-header">
                <h1>Iniciar Sesión</h1>
                <p>Bienvenido de vuelta 🥳</p>
            </div>

            <% if (typeof errors !== 'undefined' && Object.keys(errors).length > 0) { %>
                <div class="alert alert-error">
                    <p>Por favor, revisa los errores:</p>
                </div>
            <% } %>

            <form action="/users/login" method="POST">
                <div class="form-group">
                    <label for="email" class="form-label">Email</label>
                    <input 
                        type="email" 
                        id="email" 
                        name="email" 
                        class="form-control <%= (typeof errors !== 'undefined' && errors.email) ? 'is-invalid' : '' %>"
                        value="<%= (typeof old !== 'undefined' && old.email) ? old.email : '' %>" 
                        required
                    >
                    <% if (typeof errors !== 'undefined' && errors.email) { %>
                        <small class="error-message"><%= errors.email.msg %></small>
                    <% } %>
                </div>

                <div class="form-group">
                    <label for="password" class="form-label">Contraseña</label>
                    <input 
                        type="password" 
                        id="password" 
                        name="password" 
                        class="form-control <%= (typeof errors !== 'undefined' && errors.password) ? 'is-invalid' : '' %>"
                        required
                    >
                    <% if (typeof errors !== 'undefined' && errors.password) { %>
                        <small class="error-message"><%= errors.password.msg %></small>
                    <% } %>
                </div>

                <div class="form-group checkbox-group" style="display: flex; gap: 10px; align-items: center; margin-bottom: 20px;">
                    <input type="checkbox" id="remember" name="remember">
                    <label for="remember">Recordarme</label>
                </div>

                <button type="submit" class="btn btn-primary btn-block">Entrar</button>
            </form>

            <div class="auth-footer">
                <p>¿No tienes cuenta? <a href="/users/register">Regístrate aquí</a></p>
            </div>
        </div>
    </main>
    <%- include('../partials/footer') %>
</body>
</html>