<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
</head>
<body>
    <%- include('../partials/header') %>

    <main> 
        <div class="container page-content">

            <div class="page-header">
                <h1 class="page-title">
                    NUESTROS <span class="text-lime">PRODUCTOS</span>
                </h1>
                <p class="page-description">
                    Descubre toda nuestra colección de bonitos termos 🥰
                </p>

                <a href="/products/create" class="btn btn-primary" style="margin-top: 20px;">
                    ❇️ Agregar producto
                </a>
            </div>

            <div class="products-grid-full">
                <% if (products && products.length > 0) { %>
                    <% products.forEach(function(product) { %>
                        <div class="product-card">
                            <img 
                                src="<%= product.image %>" 
                                alt="<%= product.name %>" 
                                class="product-image"
                            >
                            <div class="product-info">
                                <h3 class="product-name"><%= product.name %></h3>
                                <p class="product-category"><%= product.category %></p>
                                <p class="product-price">$<%= product.price.toFixed(2) %></p>
                                <a href="/products/<%= product.id %>" class="btn btn-primary">
                                    Ver detalles
                                </a>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p class="no-products">No hay productos disponibles 😣</p>
                <% } %>
            </div>
        </div>
    </main>
    <%- include('../partials/footer') %>
</body>
</html>