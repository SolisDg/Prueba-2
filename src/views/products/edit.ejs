<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
</head>
<body>
    <%- include('../partials/header') %>
    <main>
        <div  class="container page-content">
            <h1 class="form-product">Editar producto</h1>

            <!--Formulario de edición-->
            <form action="/products/<%= product.id %>?_method=PUT" method="POST" class="form">
                <div class="form-group">
                    <label class="form-label">Nombre del producto</label>
                    <input type="text" name="name" class="form-input" value="<%= product.name %>" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Descripción</label>
                    <textarea name="description" class="form-input form-textarea" required><%= product.description %></textarea> 
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Precio $</label>
                        <input type="number" name="price" class="form-input" step="0.01" value="<%= product.price %>" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Capacidad</label>
                        <input type="text" name="capacity" class="form-input" value="<%= product.capacity %>" required>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Categoría</label>
                        <select name="category" class="form-input" required>
                            <option value="clasico" <%= product.category === 'clasico' ? 'selected' : '' %>>Clásico</option>
                            <option value="tumbler" <%= product.category === 'tumbler' ? 'selected' : '' %>>Tumbler</option>
                            <option value="deportivo" <%= product.category === 'deportivo' ? 'selected' : '' %>>Deportivo</option>
                            <option value="premium" <%= product.category === 'premium' ? 'selected' : '' %>>Premium</option>
                            <option value="mini" <%= product.category === 'mini' ? 'selected' : '' %>>Mini</option>
                        </select>
                    </div>
                    <div  class="form-group">
                        <label class="form-label">Stock</label>
                        <input type="number" name="stock" class="form-input" value="<%= product.stock %>" required>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">URL de imagen</label>
                    <input type="text" name="image" class="form-input" value="<%= product.image %>">
                </div>
                <div  class="checkbox-group">
                    <input type="checkbox" name="featured" value="true" id="featured" <%= product.featured ? 'checked' : '' %>>
                    <label for="featured" class="checkbox-label">Producto destacado</label>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Guardar cambios</button>
                    <a href="/products/<%= product.id %>" class="btn btn-outline">Cancelar</a>
                </div>
            </form>
        </div>
    </main>

    <%- include('../partials/footer') %>
    
</body>
</html>